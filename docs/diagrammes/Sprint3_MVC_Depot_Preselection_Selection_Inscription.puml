@startuml Sprint3_MVC_Depot_Preselection_Selection_Inscription
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #F8FAFC
skinparam ArrowColor #374151
skinparam ArrowThickness 1.5
skinparam packageBorderColor #7C3AED
skinparam packageFontStyle bold
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #8B5CF6
skinparam classHeaderBackgroundColor #F5F3FF

left to right direction

package "Angular 17  —  Frontend" as ANGULAR #F5F3FF {

  package "Components / Views" as AC #EDE9FE {
    class DossierComponent {
      + deposerDossier() : void
      + ajusterDossier() : void
      + uploadPiece(file) : void
    }
    class CandidaturesMasterComponent {
      + loadCandidatures() : void
      + submitAvis() : void
      + updateAvis() : void
    }
    class CandidaturesIngenieurComponent {
      + loadCandidatures() : void
      + submitDecision() : void
    }
    class CommissionDashboardComponent {
      + validerPreselection() : void
      + appliquerQuotas() : void
      + viewStatistiques() : void
      + sendAppelAvis() : void
    }
    class ListesAdmissionComponent {
      + genererListes() : void
      + publierListe() : void
      + exportPdf() : void
      + exportExcel() : void
    }
    class InscriptionAdminComponent {
      + consulterInscriptions() : void
      + importerPaiements() : void
      + rapprochementsExcel() : void
    }
    class ReclamationsComponent {
      + repondreReclamation() : void
      + rectifierScore() : void
    }
  }

  package "Services" as AS #DDD6FE {
    class DossierService {
      + deposerDossier(id, data) : Observable
      + ajusterDossier(id, data) : Observable
      + getDossierStatut(id) : Observable
    }
    class CommissionService {
      + submitAvis(cId, data) : Observable
      + updateAvis(cId, avisId, data) : Observable
      + deleteAvis(cId, avisId) : Observable
      + getStatistiques(cId) : Observable
      + validerPreselection(commId) : Observable
      + appliquerQuotas(commId) : Observable
      + sendAppelAvis(commId) : Observable
    }
    class SelectionService {
      + genererListes(masterId) : Observable
      + publierListe(listeId) : Observable
      + exportPdf(listeId) : Observable
      + exportExcel(listeId) : Observable
      + cloturerOuRelancer(masterId) : Observable
    }
    class InscriptionService {
      + consulterInscriptions() : Observable
      + importerPaiements(file) : Observable
      + rapprochementsExcel(file) : Observable
    }
    class ReclamationService {
      + repondreReclamation(id, data) : Observable
      + rectifierScore(id, data) : Observable
    }
  }

  package "Models / DTOs  (TypeScript Interfaces)" as AM #FEF9C3 {

    class DossierCandidatureDTO <<interface>> {
      + id : number
      + numero_dossier : string
      + candidature_id : number
      + numero_candidature : string
      + master_nom : string
      + statut : string
      + dossier_depose : boolean
      + dossier_valide : boolean
      + date_soumission : string
    }

    class DocumentDTO <<interface>> {
      + id : number
      + nom : string
      + icon : string
      + depose : boolean
      + fichier_url : string
      + obligatoire : boolean
      + date_depot : string
      + date_mise_a_jour : string
    }

    class AvisDTO <<interface>> {
      + id : number
      + candidature_id : number
      + membre_id : number
      + note : number
      + commentaire : string
      + recommandation : string
    }

    class ReclamationDTO <<interface>> {
      + id : number
      + identifiant : string
      + objet : string
      + master_nom : string
      + master_id : number
      + motif : string
      + date : string
      + statut : string
      + reponse : string
    }

    class DossierPreferenceFormDTO <<interface>> {
      + nom_prenom : string
      + etablissement_origine : string
      + diplome : string
      + choix_1 : string
      + choix_2 : string
      + choix_3 : string
      + numero_dossier_reserve : string
    }

    class HistoriqueItemDTO <<interface>> {
      + id : number
      + titre : string
      + description : string
      + date : string
      + master_nom : string
      + score : number
      + classement : string
      + statut_final : string
    }

    DossierCandidatureDTO --> DocumentDTO : contient
    DossierCandidatureDTO --> DossierPreferenceFormDTO : alimente
  }

}

package "Django 4  —  Backend  (candidature_service)" as DJANGO #FFFBEB {

  package "Controller  (views.py)" as DC #EDE9FE {
    class "deposer_dossier_numerique" as ddn << POST /{id}/deposer-dossier/ >>
    class "ajuster_dossier_numerique" as adn << PUT /{id}/ajuster-dossier/ >>
    class "soumettre_avis_membre" as sam << POST /{id}/avis/ >>
    class "update_avis" as ua << PUT /{id}/avis/{avisId}/update/ >>
    class "delete_avis" as da << DELETE /{id}/avis/{avisId}/delete/ >>
    class "statistiques_avis" as sta << GET /{id}/avis/statistiques/ >>
    class "valider_preselection_commission" as vpc << POST /commissions/{id}/valider-preselection/ >>
    class "appliquer_quotas_decision_finale" as aqdf << POST /commissions/{id}/appliquer-quotas/ >>
    class "send_appel_avis" as saa << POST /commissions/{id}/appel-avis/ >>
    class "generer_listes_admission" as gla << POST /master/{id}/generer-listes/ >>
    class "publier_liste" as pl << POST /listes/{id}/publier/ >>
    class "exporter_liste_pdf" as elpdf << GET /listes/{id}/export/pdf/ >>
    class "exporter_liste_excel" as elxls << GET /listes/{id}/export/excel/ >>
    class "cloture_ou_relance" as cor << POST /master/{id}/cloture-ou-relance/ >>
    class "consulter_inscriptions" as ci << GET /inscriptions-administratives/ >>
    class "importer_paiements" as ip << POST /importer-paiements/ >>
    class "rapprocher_inscriptions" as ri << POST /inscriptions/rapprochement/ >>
    class "repondre_reclamation" as rr << POST /reclamations/{id}/repondre/ >>
    class "rectifier_score_reclamation" as rsr << POST /reclamations/{id}/rectifier-score/ >>
  }

  package "Service  (services.py / tasks.py — Celery)" as DS #FEF9C3 {
    class DossierBusinessService {
      + deposer(candidature, data) : DossierNumerique
      + ajuster(candidature, data) : DossierNumerique
      + validate_pieces(dossier) : bool
      + run_ocr(piece) : dict
    }
    class PreselectionService {
      + valider_preselection(commission_id) : void
      + envoyer_email_preselection_admis(c) : void
      + envoyer_email_preselection_refuse(c) : void
      + notify_ws(user_id, payload) : void
    }
    class QuotaService {
      + apply_quotas(commission_id) : void
      + sort_by_score(candidatures) : list
      + assign_lp(c) : void
      + assign_la(c) : void
      + assign_refuse(c) : void
    }
    class AvisService {
      + submit_avis(candidature, membre, data) : Avis
      + update_avis(avis, data) : Avis
      + delete_avis(avis) : void
      + get_stats(candidature_id) : dict
    }
    class ListeAdmissionService {
      + generate_listes(master_id) : ListeAdmission
      + publish_liste(liste_id) : void
      + export_pdf(liste_id) : bytes
      + export_excel(liste_id) : bytes
    }
    class InscriptionBusinessService {
      + consult_inscriptions() : QuerySet
      + import_paiements(file) : dict
      + rapprocher(excel_data) : dict
    }
    class ReclamationService {
      + repondre(reclamation, data) : void
      + rectifier_score(reclamation, data) : void
    }
  }

  package "Repository  (ORM / models.py)" as DR #FEE2E2 {
    class DossierRepository {
      + find_by_candidature(c) : DossierNumerique
      + save(dossier) : DossierNumerique
      + find_pieces(dossier) : QuerySet
    }
    class AvisRepository {
      + find_by_candidature(c) : QuerySet
      + save(avis) : Avis
      + delete(id) : void
      + stats(candidature_id) : dict
    }
    class CommissionRepository {
      + find_by_id(id) : Commission
      + find_members(commission) : QuerySet
      + get_config(commission) : ConfigurationAppel
    }
    class ListeAdmissionRepository {
      + create(master, type) : ListeAdmission
      + find_recent(master) : ListeAdmission
      + find_by_id(id) : ListeAdmission
      + publish(liste) : void
    }
    class PaiementRepository {
      + bulk_create(data) : list
      + find_by_cin(cin) : Paiement
    }
    class ReclamationRepository {
      + find_by_id(id) : Reclamation
      + save(r) : Reclamation
    }
  }

  package "Model" as DM #F9FAFB {
    enum TypeCandidature <<enumeration>> {
      MASTER_PROFESSIONNEL : String
      MASTER_DE_RECHERCHE : String
      INGENIEUR : String
    }

    enum StatutCandidature <<enumeration>> {
      SOUMISE : String
      PRESELECTIONEE : String
      REJETEE : String
      SELECTIONEE : String
      EN_ATTENTE : String
      INSCRIPTION_CONFIRMEE : String
    }

    enum StatutAppelCandidature <<enumeration>> {
      BROUILLON : String
      OUVERT : String
      PRESELECTION : String
      SELECTION : String
      CLOTURE : String
    }

    enum StatutDossier <<enumeration>> {
      EN_ATTENTE_EXAMEN : String
      VALIDE : String
      INVALIDE : String
    }

    enum StatutAvisCommission <<enumeration>> {
      EN_ATTENTE : String
      ACCEPTE : String
      REFUSE : String
    }

    enum StatutReclamation <<enumeration>> {
      EN_ATTENTE : String
      TRAITEE : String
      INVALIDE : String
    }

    enum TypeNotificationList <<enumeration>> {
      CHANGEMENT_PREINSCRIPTION : String
      CHANGEMENT_STATUT_DOSSIER : String
      CHANGEMENT_STATUT_SELECTION : String
      PUBLICATION_APPEL_OFFRE : String
      DEMANDE_AVIS_COMMISSION : String
      REPONSE_RECLAMATION : String
    }

    class Utilisateur {
      - UID : String
      - nom : String
      - prenom : String
      - telephone : String
      - username : String
      - password : String
      - email : String
    }

    class Notification {
      - idNotif : String
      - label : String
      - contenu : String
      - dateEnvoi : Date
      - estLu : boolean
    }

    class Jeton {
      - jeton : String
      - expirationDate : Date
      - revokerd : boolean
    }

    class Role {
      - nom : String
    }

    class Action {
      - refAction : String
      - nom : String
      - description : String
    }

    class Commission {
      - codecommission : String
      - nom : String
      - dateDebut : Date
      - dateFin : Date
      - estActive : String
      - description : boolean
      + ajouterMembre() : void
      + retirerMembre() : void
      + designerResponsable() : void
      + clotureMandat() : boolean
    }

    class CalendrierAdmission {
      - code : String
      - AnneeUniversitaire : String
      + estPhaseActive() : boolean
    }

    class Echeance {
      - nom : String
      - deadline : Date
    }

    class AppelCandidature {
      - codeAppel : String
      - anneeUniversitaire : String
      - statut : StatutAppelCandidature
      - datePublication : Date
      + changerStatut() : void
      + genererClassement() : void
      + verifierPaiementsCandidats() : void
      + genererListePreselection() : void
      + genererListeSelectionFinale() : void
    }

    class ParcoursAdmission {
      - codeParcoursAdmission : String
      - intitule : String
      - description : String
      - anneeIntegration : int
      - type : Statut
      - CapaciteAccueil : int
    }

    class SpecialiteParcours {
      - nom : String
    }

    class CapaciteAccueil {
      - interne : int
      - externe : int
    }

    class TypePlace {
      - nom : String
    }

    class Candidature {
      - refCandidature : String
      - score : double
      - rang : string
      - statut : StatutCandidature
      - dateSoumission : Date
      + mettreAJourStatut() : void
      + validerPaiementInscription() : boolean
      + controllerPreuvePaiement() : void
    }

    class HistoriqueStatutCandidature {
      - statut : StatutCandidature
      - dateStatut : Date
    }

    class ParcoursAcademique {
      - titre : int
      - anneeObtention : int
      - etablissement : String
    }

    class CritereEvaluation {
      - nom : String
    }

    class ValeurCritere {
      - value : double
    }

    class DossierNumerique {
      - codeDossierNum : String
      - dateDepot : Date
      - statut : StatutDossier
      + verifierValiditePieces() : boolean
    }

    class PieceJustificative {
      - refPiece : String
      - nom : String
      - obligatoire : boolean
      - description : String
    }

    class PieceJustificativeDeposee {
      - fichierUrl : String
      - dateTelechargement : Date
      - estValide : boolean
    }

    class AvisMembreCommission {
      - note : double
      - commentaire : String
      - recommandation : StatutAvisCommission
      + modifierAvis() : void
    }

    class ConfigurationAppel {
      - codeConfiguration : String
      - minScorePreselection : double
      - maxCandidats : int
    }

    class Reclamation {
      - refReclamation : String
      - objet : String
      - description : String
      - dateDepot : Date
      - statut : StatutReclamation
      - reponse : String
      + repondreReclamation() : void
      + validerReclamation() : void
    }

    ' Relations internes du modèle
    Utilisateur "0..*" -- "0..*" Notification : concerne
    Utilisateur "1..1" -- "0..*" Jeton : utilise
    Utilisateur "1..1" -- "1..1" Role : possède
    Role "0..1" -- "0..*" Action : attribué
    Utilisateur "0..1" -- "0..*" Commission : Responsable
    Utilisateur "1..*" -- "0..*" Commission : membres
    Commission "1..1" -- "0..*" AppelCandidature : évalue / traite / gère
    CalendrierAdmission "1..1" -- "0..*" Echeance : contient
    CalendrierAdmission "1..1" -- "1..1" AppelCandidature : appartient à
    AppelCandidature "1..1" -- "1..1" ParcoursAdmission : fait l'objet de
    ParcoursAdmission "1..1" -- "1..1" SpecialiteParcours : offre
    SpecialiteParcours "1..1" -- "1..1" CapaciteAccueil
    CapaciteAccueil "1..1" -- "1..1" TypePlace : associe
    Utilisateur "1..1" -- "0..*" Candidature : dépose
    Candidature "1..1" -- "0..*" HistoriqueStatutCandidature : possède_historique
    Candidature "0..*" -- "1..1" ParcoursAcademique : porte_sur
    Candidature "1..1" -- "1..1" AppelCandidature : concerne
    CritereEvaluation "0..*" -- "1..1" ValeurCritere
    Candidature "1..1" -- "0..1" DossierNumerique : est lié à
    DossierNumerique "1..1" -- "0..*" PieceJustificativeDeposee : contient
    PieceJustificative "1..1" -- "0..*" PieceJustificativeDeposee : définit
    Commission "1..1" -- "0..*" ConfigurationAppel : configure
    AppelCandidature "1..1" -- "0..1" ConfigurationAppel : applique
    Utilisateur "1..1" -- "0..*" AvisMembreCommission : donne
    Candidature "1..1" -- "0..*" AvisMembreCommission : reçoit
    Candidature "1..1" -- "0..*" Reclamation : fait l'objet de
    Utilisateur "1..1" -- "0..*" Reclamation : soumet
  }

}

' Angular internal
DossierComponent --> DossierService
CandidaturesMasterComponent --> CommissionService
CandidaturesIngenieurComponent --> CommissionService
CommissionDashboardComponent --> CommissionService
CommissionDashboardComponent --> SelectionService
ListesAdmissionComponent --> SelectionService
InscriptionAdminComponent --> InscriptionService
ReclamationsComponent --> ReclamationService
DossierService ..> AM
CommissionService ..> AM
SelectionService ..> AM

' Django internal
ddn --> DossierBusinessService
adn --> DossierBusinessService
sam --> AvisService
ua --> AvisService
da --> AvisService
sta --> AvisService
vpc --> PreselectionService
aqdf --> QuotaService
saa --> PreselectionService
gla --> ListeAdmissionService
pl --> ListeAdmissionService
elpdf --> ListeAdmissionService
elxls --> ListeAdmissionService
cor --> ListeAdmissionService
ci --> InscriptionBusinessService
ip --> InscriptionBusinessService
ri --> InscriptionBusinessService
rr --> ReclamationService
rsr --> ReclamationService

DossierBusinessService --> DossierRepository
PreselectionService --> CommissionRepository
QuotaService --> CommissionRepository
AvisService --> AvisRepository
ListeAdmissionService --> ListeAdmissionRepository
InscriptionBusinessService --> PaiementRepository
ReclamationService --> ReclamationRepository

DossierRepository ..> DM
AvisRepository ..> DM
CommissionRepository ..> DM
ListeAdmissionRepository ..> DM
PaiementRepository ..> DM
ReclamationRepository ..> DM

@enduml
