@startuml Sprint4_Sequence_OCR_ListeOfficielle

skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #F8FAFC
skinparam ArrowColor #374151
skinparam SequenceLifeLineBorderColor #94A3B8
skinparam SequenceLifeLineBorderThickness 1

skinparam actor {
  BackgroundColor #DBEAFE
  BorderColor #1D4ED8
  FontColor #1E3A5F
  FontStyle bold
}

skinparam participant {
  BackgroundColor #FFFFFF
  BorderColor #8B5CF6
  FontColor #1E293B
}

skinparam note {
  BackgroundColor #FEFCE8
  BorderColor #CA8A04
  FontColor #713F12
}

skinparam sequence {
  DividerBackgroundColor #EDE9FE
  DividerBorderColor #7C3AED
  DividerFontColor #4C1D95
  DividerFontStyle bold
  GroupBackgroundColor #F0FDF4
  GroupBorderColor #15803D
  GroupFontColor #14532D
  GroupFontStyle bold
  GroupHeaderFontStyle bold
}

actor "Responsable Commission" as RESP

participant "Vue Angular\n(DashboardCommission)" as VUE #D6E4FF
participant "OCRController\n(Django REST)" as CTRL_OCR #FEF9C3
participant "ListeOfficielleController\n(Django REST)" as CTRL_LISTE #FEF9C3
participant "OCRService" as SVC_OCR #A7F3D0
participant "QRCodeService" as SVC_QR #A7F3D0
participant "ExportService" as SVC_EXPORT #A7F3D0
participant "CandidatureRepository" as REPO #E2E8F0
participant "Système IA / OCR" as IA #FCE7F3
database "Base de données\n(PostgreSQL)" as DB #F1F5F9

' ─────────────────────────────────────────────────────
== US 7.1 — Étude d'un dossier avec module OCR ==
' ─────────────────────────────────────────────────────

RESP -> VUE : Ouvrir le dossier d'une candidature
VUE -> CTRL_OCR : GET /api/dossiers/{id}/
CTRL_OCR -> REPO : findDossierById(id)
REPO -> DB : SELECT dossier, pieces_jointes\nWHERE candidature_id = ?
DB --> REPO : Dossier + URLs fichiers
REPO --> CTRL_OCR : DossierDTO
CTRL_OCR --> VUE : 200 OK { dossier, fichiers, statut_ocr }
VUE --> RESP : Affichage des pièces jointes\n+ résultats OCR si déjà analysés

' ─────────────────────────────────────────────────────
== US 7.2 — Lancement de l'analyse OCR en lot ==
' ─────────────────────────────────────────────────────

RESP -> VUE : Sélectionner N candidatures\n→ "Lancer l'analyse OCR"
VUE -> CTRL_OCR : POST /api/ocr/analyser-lot/\n{ candidature_ids: [id1, id2, …idN] }
CTRL_OCR -> SVC_OCR : lancerAnalyseLot(ids)

group Boucle — Pour chaque candidature sélectionnée
  SVC_OCR -> REPO : getDossierFichiers(candidature_id)
  REPO -> DB : SELECT fichiers WHERE candidature_id = ?
  DB --> REPO : [relevé_de_notes.pdf, …]
  REPO --> SVC_OCR : liste des fichiers
  SVC_OCR -> IA : extraireTexte(relevé_de_notes.pdf)
  IA --> SVC_OCR : { texte_brut, moyennes_extraites[] }
  SVC_OCR -> SVC_OCR : comparerDeclaresVsExtraits(\n  moyennes_declarees, moyennes_extraites)
  SVC_OCR -> REPO : sauvegarderRapportOCR(\n  candidature_id, rapport, statut)
  REPO -> DB : UPDATE dossier SET\n  statut_ocr, rapport_ocr, date_analyse
  DB --> REPO : OK
end

REPO --> SVC_OCR : Tous rapports sauvegardés
SVC_OCR --> CTRL_OCR : { resultats: [...],\n  nb_conformes, nb_incoherences }
CTRL_OCR --> VUE : 200 OK { resultats_ocr }
VUE --> RESP : Tableau récapitulatif :\nConformes ✓ / Incohérences ⚠

' ─────────────────────────────────────────────────────
== US 7.3 — Détection automatique des incohérences ==
' ─────────────────────────────────────────────────────

note over IA, SVC_OCR
  Le module IA extrait les moyennes de chaque semestre
  depuis le PDF du relevé de notes (OCR + parsing).
  Si |moyenne_extraite – moyenne_declaree| > seuil (0.5),
  le dossier est marqué "Incohérence détectée".
end note

IA -> SVC_OCR : { module, moy_extraite,\n  moy_declaree, ecart, statut }
SVC_OCR -> CTRL_OCR : rapportIncoherence(candidature_id, details)
CTRL_OCR -> VUE : Événement SSE / WebSocket :\n{ candidature_id, statut: "incoherence" }
VUE --> RESP : Badge dossier mis à jour :\n"Conforme" (vert) / "Incohérence" (rouge)

' ─────────────────────────────────────────────────────
== US 8.1 — Génération de la liste officielle avec QR code ==
' ─────────────────────────────────────────────────────

RESP -> VUE : Cliquer sur "Générer la liste officielle"
VUE -> CTRL_LISTE : POST /api/liste-officielle/generer/
CTRL_LISTE -> REPO : getCandidaturesSelectionnees()
REPO -> DB : SELECT candidature WHERE statut = 'selectionne'\nORDER BY score DESC
DB --> REPO : Liste ordonnée des candidats retenus
REPO --> CTRL_LISTE : [CandidatureDTO, …]

group Boucle — Pour chaque candidat retenu
  CTRL_LISTE -> SVC_QR : genererQRCode(\n  candidat_id, hash_unique, nom, master)
  SVC_QR --> CTRL_LISTE : qr_code_base64
end

CTRL_LISTE -> REPO : sauvegarderListeOfficielle(\n  session_id, liste_avec_qrcodes)
REPO -> DB : INSERT INTO liste_officielle\n(session_id, candidat_id, qr_code, rang)
DB --> REPO : OK
REPO --> CTRL_LISTE : ListeOfficielleDTO
CTRL_LISTE --> VUE : 200 OK { liste, qr_codes, url_pdf }
VUE --> RESP : Liste officielle affichée\navec QR code par candidat

' ─────────────────────────────────────────────────────
== US 8.2 — Export du rapport de conformité OCR (Excel / PDF) ==
' ─────────────────────────────────────────────────────

RESP -> VUE : "Exporter le rapport OCR"\n→ Choisir Excel ou PDF
VUE -> CTRL_LISTE : GET /api/ocr/rapport-conformite/\n?format=excel  [ou ?format=pdf]
CTRL_LISTE -> REPO : getResultatsOCRBySession(session_id)
REPO -> DB : SELECT rapport_ocr, statut_ocr\nWHERE session_id = ?
DB --> REPO : [{ candidature, statut, ecarts, … }]
REPO --> CTRL_LISTE : [RapportOCRDTO]
CTRL_LISTE -> SVC_EXPORT : genererRapport(resultats, format)

alt format = "excel"
  SVC_EXPORT --> CTRL_LISTE : fichier .xlsx (openpyxl)
else format = "pdf"
  SVC_EXPORT --> CTRL_LISTE : fichier .pdf (ReportLab)
end

CTRL_LISTE --> VUE : 200 OK + fichier binaire\n(Content-Disposition: attachment)
VUE --> RESP : Téléchargement automatique\ndu rapport de conformité

@enduml
