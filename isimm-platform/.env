DB_NAME=isimm_db
DB_USER=isimm_user
DB_PASSWORD=isimm_dev_password_2026
DB_HOST=db
DB_PORT=5432

# ============================================
# Django Configuration
# ============================================
DEBUG=False
SECRET_KEY=django-insecure-dev-key-for-local-testing-only-min-50-chars-required-now
ALLOWED_HOSTS=localhost,127.0.0.1,gateway,auth-service,user-service,candidature-service
TIMEZONE=UTC

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=jwt-dev-secret-key-for-local-testing-only-min-50-chars-required-now
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80,http://localhost,http://127.0.0.1,http://gateway

# ============================================
# Email Configuration (Optional)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=dev@example.com
EMAIL_HOST_PASSWORD=dev-password
EMAIL_USE_TLS=True

# ============================================
# AWS S3 Configuration (Optional)
# ============================================
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# Nginx/Gateway Configuration
# ============================================
GATEWAY_HOST=localhost
GATEWAY_PORT=80
GATEWAY_SSL=False

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# ============================================
# Feature Flags
# ============================================
ENABLE_API_DOCS=True
ENABLE_WEBSOCKET=True
ENABLE_FILE_UPLOAD=True
MAX_FILE_SIZE=52428800  # 50MB in bytes
