@startuml
title Sprint 2 - Diagramme de classes (Preinscription) conforme a la plateforme

hide empty members
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam backgroundColor #f5f5f5

package "Types enumeres" #F3F7FF {
  enum RoleUtilisateur {
    candidat
    commission
    responsable_commission
    admin
  }

  enum TypeMaster {
    professionnel
    recherche
  }

  enum TypeConcours {
    master
    ingenieur
  }

  enum StatutCandidature {
    soumis
    annule
    sous_examen
    rejete
    preselectionne
    en_attente_dossier
    dossier_non_depose
    dossier_depose
    en_attente
    selectionne
    inscrit
  }

  enum TypeNotification {
    info
    success
    warning
    danger
  }

  enum StatutDossier {
    en_cours
    soumis
    en_verification
    incomplet
    complet
    rejete
  }

  enum TypeDocument {
    diplome
    releve_notes
    cv
    lettre_motivation
    certificat_langue
    attestation_travail
    autre
  }

  enum Mention {
    passable
    assez_bien
    bien
    tres_bien
  }
}

package "Acteurs metier (specialisation de User)" #EAF4FF {
  abstract class User {
    +id: int
    +email: string
    +username: string
    +first_name: string
    +last_name: string
    +role: RoleUtilisateur
  }

  class Candidat {
    +postuler(offre): Candidature
    +modifierCandidature(candidature): void
    +consulterEtat(candidature): StatutCandidature
    +consulterScoreEtClassement(candidature): decimal/int
    +consulterNotifications(): Notification[]
  }

  class CommissionUtilisateur {
    +evaluer(candidature): void
    +changerStatut(candidature, statut): void
    +publierListes(master): void
  }
}

package "Offres d appel" #E8FFF5 {
  class Master {
    +id: int
    +nom: string
    +type_master: TypeMaster
    +specialite: string
    +places_disponibles: int
    +date_limite_candidature: date
    +annee_universitaire: string
    +actif: bool
  }

  class Concours {
    +id: int
    +nom: string
    +type_concours: TypeConcours
    +date_ouverture: date
    +date_cloture: date
    +places_disponibles: int
    +actif: bool
  }

  class ConfigurationAppel {
    +id: int
    +date_debut_visibilite: date
    +date_fin_visibilite: date
    +date_limite_preinscription: date
    +date_limite_depot_dossier: date
    +delai_modification_candidature_jours: int
    +capacite_accueil: int
    +capacite_interne: int
    +capacite_externe: int
    +est_cache: bool
  }

  class Commission {
    +id: int
    +nom: string
    +delai_preselection: int
    +delai_depot_dossier: int
    +delai_paiement: int
    +actif: bool
  }

  class MembreCommission {
    +id: int
    +role: string (responsable|membre)
    +actif: bool
  }
}

package "Preinscription - Dossier - Resultats" #FFF4E8 {
  class Candidature {
    +id: int
    +numero: string
    +statut: StatutCandidature
    +score: decimal
    +classement: int
    +date_soumission: datetime
    +date_limite_modification: datetime
    +peut_modifier: bool
    +dossier_depose: bool
    +date_depot_dossier: datetime
    +motif_rejet: text
    --
    +peut_etre_modifie(): bool
    +peut_etre_annulee(): bool
    +ajouter_historique(...): void
  }

  class DonneesAcademiques {
    +id: int
    +moyenne_generale: decimal
    +moyenne_specialite: decimal
    +note_pfe: decimal
    +mention: Mention
    +nb_redoublements: int
    +nb_dettes: int
    --
    +calculer_et_sauvegarder_score(): decimal
  }

  class FormuleScore {
    +id: int
    +nom: string
    +coef_moyenne_generale: decimal
    +coef_moyenne_specialite: decimal
    +coef_note_pfe: decimal
    +bonus_mention_tres_bien: decimal
    +bonus_mention_bien: decimal
    +bonus_mention_assez_bien: decimal
    +malus_redoublement: decimal
    +malus_dette: decimal
    --
    +calculer_score(donnees): decimal
  }

  class Dossier {
    +id: int
    +statut: StatutDossier
    +date_depot: datetime
    +date_limite_depot: datetime
    +nb_documents_attendus: int
    +nb_documents_soumis: int
    +score_completude: decimal
    --
    +calculer_completude(): decimal
  }

  class DocumentType {
    +id: int
    +type_document: TypeDocument
    +obligatoire: bool
    +taille_max_mb: int
    +formats_acceptes: json
  }

  class Document {
    +id: int
    +nom_fichier_original: string
    +format_fichier: string
    +statut: string
    +score_ocr: decimal
    +date_upload: datetime
    +celery_task_id: string
  }

  class ValidationDocument {
    +id: int
    +statut: string (accepte|rejete|en_attente)
    +commentaires: text
    +date_validation: datetime
  }

  class Notification {
    +id: int
    +titre: string
    +message: text
    +type: TypeNotification
    +lue: bool
    +created_at: datetime
  }

  class ListeAdmission {
    +id: int
    +type_liste: string (principale|attente)
    +iteration: int
    +publiee: bool
    +date_publication: datetime
  }

  class CandidatListe {
    +id: int
    +position: int
    +score: decimal
    +a_paye: bool
    +a_confirme_inscription: bool
  }
}

' Heritage demande: Candidat et Commission heritent de User
Candidat --|> User
CommissionUtilisateur --|> User

' Association demandee: offre d appel et candidat (via candidature)
Candidat "1" -- "0..*" Candidature : postule
Master "1" -- "0..*" Candidature : recoit candidatures
Concours "0..1" -- "0..*" Candidature : recoit candidatures

Master "1" -- "0..1" ConfigurationAppel : configuration
Master "1" -- "0..1" Commission : pilotee par
Commission "1" -- "0..*" MembreCommission : contient
MembreCommission "0..*" --> "1" CommissionUtilisateur : user

Candidature "1" -- "0..1" DonneesAcademiques : porte
Master "1" -- "0..1" FormuleScore : formule
DonneesAcademiques --> FormuleScore : calcule score avec

Candidature "1" -- "0..1" Dossier : depot
Dossier "1" -- "0..*" Document : contient
Master "1" -- "0..*" DocumentType : exige
Document --> DocumentType : type
Document "1" -- "0..1" ValidationDocument : validation
ValidationDocument --> CommissionUtilisateur : valide_par

Candidat "1" -- "0..*" Notification : recoit
Candidature "0..*" --> "1" Candidat : appartient a

Master "1" -- "0..*" ListeAdmission : publie
ListeAdmission "1" -- "0..*" CandidatListe : lignes
CandidatListe --> Candidature : reference

note right of Candidature
US 3.1: postuler a master ou concours ingenieur
US 3.2: modifier avant delai (date_limite_modification)
US 3.3: consulter etat (statut)
US 3.4: notification email lors changement de statut
US 3.5: consulter score et classement
end note

note top of Master
Dans la plateforme, l offre d appel est publiee via:
Master + ConfigurationAppel (+ option Concours ingenieur).
end note

note bottom of Candidat
Association offre/candidat satisfaite par la classe Candidature
(table de liaison metier entre Candidat et offre publiee).
end note

@enduml
